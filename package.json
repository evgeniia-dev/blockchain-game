{
  "name": "market-island-fullstack",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "homepage": "https://evgeniia-dev.github.io/blockchain-game",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "node server/index.js",
    "client": "vite client --host 0.0.0.0 --port 5173",
    "build": "vite build client",
    "preview": "vite preview --host 0.0.0.0 --port 4173",
    "predeploy": "npm run build",
    "deploy": "gh-pages -d client/dist"
  },
  "dependencies": {
    "concurrently": "^9.1.2",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "gh-pages": "^6.3.0",
    "vite": "^5.4.19"
  }
}
